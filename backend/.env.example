# Database Configuration
# For security, consider using a dedicated database user with limited privileges
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=project_tracker
# For remote connections, consider using SSL:
# DB_SSL=true

# Redis Configuration
# For security, consider changing the default port and requiring authentication
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password_here
# For Redis ACL (Redis 6+), configure user permissions appropriately

# Server Configuration
# Binding to 0.0.0.0 makes the service available on all network interfaces
# In production, consider using a firewall to restrict access
HOST=0.0.0.0
PORT=5000

# CORS Configuration
# In production, set this to your actual frontend domain
# Example: FRONTEND_URL=https://yourdomain.com
FRONTEND_URL=

# Node Environment
# Set to 'production' in production environments
NODE_ENV=development